local TOGGLE_KEY = Enum.KeyCode.X
local enabled = false
local terminated = false
local runningThread = nil
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local player = Players.LocalPlayer

local gui = Instance.new("ScreenGui")
gui.Name = "ToggleCircleGUI"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0,50,0,50)
button.Position = UDim2.new(0,10,0,70)
button.BackgroundColor3 = Color3.fromRGB(255,60,60)
button.Text = ""
button.Parent = gui
Instance.new("UICorner", button).CornerRadius = UDim.new(1,0)
local stroke = Instance.new("UIStroke")
stroke.Thickness = 2
stroke.Transparency = 0.5
stroke.Parent = button

local terminateButton = Instance.new("Frame")
terminateButton.Size = UDim2.new(0,18,0,18)
terminateButton.Position = UDim2.new(0,70,0,75)
terminateButton.BackgroundColor3 = Color3.fromRGB(255,60,60)
terminateButton.Parent = gui
Instance.new("UICorner", terminateButton).CornerRadius = UDim.new(1,0)

-- Invisible color controller
local colorController = Instance.new("Folder")
colorController.Name = "RainbowController"
colorController.Parent = gui
local rainbowValue = Instance.new("Color3Value")
rainbowValue.Value = Color3.fromRGB(255,0,0)
rainbowValue.Name = "CurrentColor"
rainbowValue.Parent = colorController

-- Faster rainbow update
task.spawn(function()
	local hue = 0
	while true do
		hue = (hue + 0.01) % 1 -- increased from 0.002 to 0.01 for faster cycling
		rainbowValue.Value = Color3.fromHSV(hue,0.9,1)
		task.wait(0.03)
	end
end)

local function getRole(plr)
	if (plr.Backpack:FindFirstChild("Knife") or (plr.Character and plr.Character:FindFirstChild("Knife"))) then
		return "Murderer", Color3.fromRGB(255,0,0)
	elseif (plr.Backpack:FindFirstChild("Gun") or (plr.Character and plr.Character:FindFirstChild("Gun"))) then
		return "Sheriff", Color3.fromRGB(0,120,255)
	else
		return "Innocent", Color3.fromRGB(0,255,0)
	end
end

local function createTag(character, plr)
	local head = character:FindFirstChild("Head")
	if not head then return end
	if head:FindFirstChild("RoleTag") then head.RoleTag:Destroy() end

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "RoleTag"
	billboard.Size = UDim2.new(0,200,0,50)
	billboard.StudsOffset = Vector3.new(0,3,0)
	billboard.AlwaysOnTop = true
	billboard.Parent = head

	local roleText = Instance.new("TextLabel")
	roleText.Size = UDim2.new(1,0,0.6,0)
	roleText.BackgroundTransparency = 1
	roleText.TextScaled = true
	roleText.Font = Enum.Font.GothamBold
	roleText.TextStrokeTransparency = 0.5
	roleText.Text = getRole(plr)
	roleText.Parent = billboard

	local nameText = Instance.new("TextLabel")
	nameText.Size = UDim2.new(1,0,0.4,0)
	nameText.Position = UDim2.new(0,0,0.6,0)
	nameText.BackgroundTransparency = 1
	nameText.TextScaled = true
	nameText.Font = Enum.Font.Gotham
	nameText.TextStrokeTransparency = 0.5
	nameText.Text = plr.Name
	nameText.Parent = billboard

	task.spawn(function()
		while roleText.Parent and enabled do
			roleText.TextColor3 = rainbowValue.Value
			nameText.TextColor3 = rainbowValue.Value
			task.wait()
		end
	end)
end

local function stopMarkers()
	if runningThread then task.cancel(runningThread) end
	for _, v in pairs(Players:GetPlayers()) do
		if v.Character then
			if v.Character:FindFirstChild("Highlight") then
				v.Character.Highlight:Destroy()
			end
			local head = v.Character:FindFirstChild("Head")
			if head and head:FindFirstChild("RoleTag") then
				head.RoleTag:Destroy()
			end
		end
	end
end

local function startMarkers()
	runningThread = task.spawn(function()
		while enabled do
			for _, v in pairs(Players:GetPlayers()) do
				if v ~= player and v.Character then
					local role, color = getRole(v)
					local hl = v.Character:FindFirstChild("Highlight")
					if not hl then
						hl = Instance.new("Highlight",v.Character)
					end
					hl.FillTransparency = 0.3
					hl.OutlineTransparency = 0.2
					hl.FillColor = color
					createTag(v.Character,v)
				end
			end
			task.wait(0.2)
		end
	end)
end

local function toggleMarkers()
	if terminated then return end
	enabled = not enabled
	if enabled then
		button.BackgroundColor3 = Color3.fromRGB(60,255,100)
		startMarkers()
	else
		button.BackgroundColor3 = Color3.fromRGB(255,60,60)
		stopMarkers()
	end
end

button.MouseButton1Click:Connect(toggleMarkers)

UIS.InputBegan:Connect(function(input,gameProcessed)
	if gameProcessed then return end
	if input.KeyCode == TOGGLE_KEY and not terminated then
		toggleMarkers()
	end
end)

terminateButton.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		terminated = true
		enabled = false
		stopMarkers()
		gui:Destroy()
		button:Destroy()
		terminateButton:Destroy()
		runningThread = nil
	end
end)
